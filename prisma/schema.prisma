generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMATION_PENDING
  CONFIRMED
  CANCELLED
  RESCHEDULE_REQUESTED
  RESCHEDULED
}

enum AppointmentSource {
  RECURRING
  RESCHEDULE
}

enum MessageKind {
  CONFIRMATION
  RESCHEDULE_OPTIONS
}

enum MessageDirection {
  OUTBOUND
  INBOUND
}

enum MessageStatus {
  SENT
  RECEIVED
  PROCESSED
}

model Patient {
  id                String              @id @default(cuid())
  fullName          String
  phoneNumber       String              @unique
  email             String?
  notes             String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  recurringSchedule RecurringSchedule?
  appointments      Appointment[]
}

model RecurringSchedule {
  id              String        @id @default(cuid())
  patientId       String        @unique
  weekday         Int
  startTime       String
  durationMinutes Int
  active          Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  patient         Patient       @relation(fields: [patientId], references: [id], onDelete: Cascade)
  appointments    Appointment[]
}

model Appointment {
  id                    String              @id @default(cuid())
  patientId             String
  recurringScheduleId   String?
  originalAppointmentId String?
  startsAt              DateTime
  endsAt                DateTime
  status                AppointmentStatus   @default(SCHEDULED)
  source                AppointmentSource   @default(RECURRING)
  confirmationSentAt    DateTime?
  confirmedAt           DateTime?
  cancellationReason    String?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  patient               Patient             @relation(fields: [patientId], references: [id], onDelete: Cascade)
  recurringSchedule     RecurringSchedule?  @relation(fields: [recurringScheduleId], references: [id], onDelete: SetNull)
  originalAppointment   Appointment?        @relation("AppointmentRescheduleChain", fields: [originalAppointmentId], references: [id], onDelete: SetNull)
  rescheduledChildren   Appointment[]       @relation("AppointmentRescheduleChain")
  messageInteractions   MessageInteraction[]

  @@index([startsAt, endsAt])
  @@index([patientId, startsAt])
}

model PsychologistAvailability {
  id        String   @id @default(cuid())
  weekday   Int
  startTime String
  endTime   String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([weekday, active])
}

model AvailabilityBlock {
  id        String   @id @default(cuid())
  startAt   DateTime
  endAt     DateTime
  reason    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([startAt, endAt])
}

model MessageInteraction {
  id            String           @id @default(cuid())
  appointmentId String
  kind          MessageKind
  direction     MessageDirection
  status        MessageStatus
  provider      String           @default("mock")
  channel       String           @default("whatsapp")
  content       String
  responseCode  String?
  metadata      Json?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  appointment   Appointment      @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([appointmentId, createdAt])
}
